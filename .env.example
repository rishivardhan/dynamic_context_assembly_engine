# PostgreSQL
DATABASE_URL=postgresql://dcae:dcae_secret@localhost:5432/dcae_db

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dcae_neo4j_secret

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Scoring weights (optional overrides)
WEIGHT_SEMANTIC=0.30
WEIGHT_TEMPORAL=0.25
WEIGHT_AUTHORITY=0.15
WEIGHT_RISK=0.20
WEIGHT_PROJECT=0.10

# LLM Gateway (optional — for generating answers, not required for PoC)
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434
